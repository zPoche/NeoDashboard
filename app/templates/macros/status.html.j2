{# Moderation status icons: approved (green), rejected (red), pending (muted) #}
{% macro moderation_status(approved=false, rejected=false) %}
  {% if approved %}
    <h5 class="far fa-check-square text-success"></h5>
  {% elif rejected %}
    <h5 class="far fa-times-circle text-danger"></h5>
  {% else %}
    <h5 class="far fa-times-circle text-muted"></h5>
  {% endif %}
{% endmacro %}

{# Boolean flag: active/yes (green), inactive/no (muted) #}
{% macro flag_status(active=false) %}
  {% if active %}
    <h5 class="far fa-check-square text-success"></h5>
  {% else %}
    <h5 class="far fa-times-circle text-muted"></h5>
  {% endif %}
{% endmacro %}
