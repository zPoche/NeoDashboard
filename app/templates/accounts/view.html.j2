{% extends 'base.html.j2' %}

{% block title %}
  Viewing {{ account_data.username }}
{% endblock %}

{% block content_before %}
  Viewing {{ account_data.username }}
  {% if current_user.id == account_data.id %}
    <br/>
     Hey, this is you!
  {% endif %}
{% endblock %}

{% block content %}
  {% include 'partials/_account.html.j2' %}
  {% if current_user.gm_level >= 3 and current_user.id != account_data.id and account_data.gm_level < current_user.gm_level %}
    <br/>
    <div class="text-center">
      <a role="button" class="btn btn-warning"
        href='{{ url_for('accounts.add_strike', id=account_data.id) }}'>
        Issue Strike
      </a>
      <span class="text-muted ml-2">{{ active_strike_count }} active strike(s)</span>
    </div>
  {% endif %}
  {% if strikes %}
    <br/>
    <h3 class="text-center">Strike History</h3>
    <hr class="bg-primary"/>
    <table class="table table-dark table-striped table-bordered">
      <thead>
        <tr>
          <th>Date</th>
          <th>Source</th>
          <th>Reason</th>
          <th>Active</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {% for strike in strikes %}
          <tr>
            <td>{{ strike.created_at }}</td>
            <td>{{ strike.source_type }}{% if strike.source_id %} #{{ strike.source_id }}{% endif %}</td>
            <td>{{ strike.reason }}</td>
            <td>{{ 'Yes' if strike.active else 'No' }}</td>
            <td>{{ strike.action_taken or '—' }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
{% endblock content %}


{% block content_after %}
  <br/>
  <br/>
  <h3 class="text-center">Characters</h3>
  <hr class="bg-primary"/>
  <div class="card-columns">
    {% for character in account_data.charinfo %}
      {% include 'partials/_character.html.j2' %}
    {% endfor %}
  </div>
{% endblock content_after %}
